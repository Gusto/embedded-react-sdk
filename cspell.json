{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "dictionaries": ["en_US", "node", "typescript", "npm", "softwareTerms", "html", "css"],
  "files": ["docs/**/*.md", "docs-site/**/*.{md,mdx,ts,tsx}"],
  "ignorePaths": [
    "**/node_modules/**",
    "docs/api/**",
    "docs/reference/endpoint-reference.md",
    "docs/reference/endpoint-inventory.json",
    "docs/test-fests/**",
    "docs-site/build/**",
    "docs-site/.docusaurus/**",
    "docs-site/versioned_docs/**",
    "CHANGELOG.md"
  ],
  "ignoreRegExpList": [
    "https?://\\S+",
    "```[\\s\\S]*?```",
    "<!--[\\s\\S]*?-->",
    "\\w*&[a-z]+;\\w*"
  ],
  "words": [
    "affordances",
    "Annualization",
    "autogeneration",
    "Chakra",
    "easyops",
    "FLSA",
    "FSLA",
    "gdev",
    "Gwsflows",
    "Juneteenth",
    "mgmt",
    "NAICS",
    "numericality",
    "pasteable",
    "paystub",
    "paystubs",
    "refetches",
    "reflectionname",
    "reparent",
    "requiredness",
    "subcomponent",
    "subcomponents",
    "summarising",
    "themable",
    "themself",
    "zenpayroll"
  ]
}
