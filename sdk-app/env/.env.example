# SDK Dev App - Environment Configuration (Demo/Staging)
#
# For demo:    Copy to .env.demo and run: npm run sdk-app:setup --env=demo
# For staging: Copy to .env.staging and run: npm run sdk-app:setup --env=staging
#
# The setup script will auto-populate FLOW_TOKEN, VITE_COMPANY_ID, and entity IDs.

# GWS-Flows host for this environment
GWS_FLOWS_HOST=https://flows.gusto-demo.com

# Flow token (auto-populated by setup script)
FLOW_TOKEN=

# Company ID (auto-populated by setup script)
VITE_COMPANY_ID=

# Entity IDs (auto-populated, can be overridden in the app UI)
VITE_EMPLOYEE_ID=
VITE_CONTRACTOR_ID=
VITE_PAYROLL_ID=
VITE_REQUEST_ID=

# Demo type used to create this environment
VITE_DEMO_TYPE=react_sdk_demo_company_onboarded
