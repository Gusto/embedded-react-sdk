# SDK Dev App - Local ZenPayroll (via local gws-flows)
#
# This file is auto-generated on first run of: npm run sdk-app-dev --env=local
# It uses your local gws-flows instance to create demos against local ZenPayroll.
#
# Prerequisites:
#   - ZenPayroll running locally
#   - gws-flows running locally on port 7777
#
# You generally don't need to create or edit this file manually.
# Just run: npm run sdk-app-dev --env=local

GWS_FLOWS_HOST=http://localhost:7777
