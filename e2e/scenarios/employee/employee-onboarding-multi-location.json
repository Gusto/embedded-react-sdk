{
  "$schema": "../../schema/scenario.schema.json",
  "name": "Employee onboarding with multi-location workforce",
  "description": "Onboarded company with two locations so employee onboarding's work-address picker has multiple options.",
  "domain": "employee",
  "baseDemo": "react_sdk_demo_company_onboarded",
  "decorations": {
    "locations": [
      {
        "key": "hq",
        "street_1": "100 Onboarding St",
        "city": "San Francisco",
        "state": "CA",
        "zip": "94105",
        "filing_address": true,
        "mailing_address": true
      },
      {
        "key": "second",
        "street_1": "200 Second Ave",
        "city": "Oakland",
        "state": "CA",
        "zip": "94607"
      }
    ]
  },
  "expectedContext": ["companyId", "locationIds.hq", "locationIds.second"]
}
