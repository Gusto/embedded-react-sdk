{
  "$schema": "../../schema/scenario.schema.json",
  "name": "Off-cycle eligible (one processed payroll)",
  "description": "Company with one processed regular payroll so off-cycle is allowed.",
  "domain": "payroll",
  "baseDemo": "react_sdk_demo_company_onboarded",
  "decorations": {
    "locations": [
      {
        "key": "hq",
        "street_1": "200 Test Ave",
        "city": "San Francisco",
        "state": "CA",
        "zip": "94105",
        "filing_address": true,
        "mailing_address": true
      }
    ],
    "employees": [
      {
        "key": "alice",
        "$ref": "../fragments/w2-salaried-employee.json",
        "overrides": {
          "first_name": "Alice",
          "last_name": "Anderson",
          "email": "alice-oc+{{ts}}@example.com"
        }
      }
    ],
    "paySchedule": {
      "frequency": "Every other week",
      "anchor_pay_date": "{{relative:+14d:Friday}}",
      "anchor_end_of_pay_period": "{{relative:+13d}}"
    },
    "payrolls": [
      {
        "key": "history-1",
        "type": "regular",
        "status": "processed"
      }
    ]
  },
  "expectedContext": ["companyId", "employeeIds.alice"]
}
