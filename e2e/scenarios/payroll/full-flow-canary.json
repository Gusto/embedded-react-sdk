{
  "$schema": "../../schema/scenario.schema.json",
  "name": "Full-flow payroll canary",
  "description": "Single onboarded company shared across the payroll canary suite. The suite drives this company through regular payroll, off-cycle bonus, off-cycle correction, transition, and dismissal payrolls — each step exercised via the SDK UI. No payrolls pre-provisioned; each spec creates what it needs.",
  "domain": "payroll",
  "baseDemo": "react_sdk_demo_company_onboarded",
  "decorations": {
    "locations": [
      {
        "key": "hq",
        "street_1": "500 Canary Way",
        "city": "San Francisco",
        "state": "CA",
        "zip": "94105",
        "filing_address": true,
        "mailing_address": true
      }
    ],
    "employees": [
      {
        "key": "alice",
        "$ref": "../fragments/w2-salaried-employee.json",
        "overrides": {
          "first_name": "Alice",
          "last_name": "Canary",
          "email": "alice-canary+{{ts}}@example.com"
        }
      },
      {
        "key": "bob",
        "$ref": "../fragments/w2-hourly-employee.json",
        "overrides": {
          "first_name": "Bob",
          "last_name": "Canary",
          "email": "bob-canary+{{ts}}@example.com"
        }
      },
      {
        "key": "carol",
        "$ref": "../fragments/w2-salaried-employee.json",
        "overrides": {
          "first_name": "Carol",
          "last_name": "Canary",
          "email": "carol-canary+{{ts}}@example.com",
          "compensation": {
            "rate": "95000",
            "payment_unit": "Year",
            "flsa_status": "Exempt"
          }
        }
      }
    ],
    "paySchedule": {
      "frequency": "Every other week",
      "anchor_pay_date": "{{relative:+14d:Friday}}",
      "anchor_end_of_pay_period": "{{relative:+13d}}"
    }
  },
  "expectedContext": [
    "companyId",
    "locationIds.hq",
    "employeeIds.alice",
    "employeeIds.bob",
    "employeeIds.carol",
    "paySchedule.uuid"
  ]
}
