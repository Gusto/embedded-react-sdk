{
  "$schema": "../schema/scenario.schema.json",
  "name": "Minimal payroll scenario (1 employee, biweekly)",
  "description": "Smallest possible Payroll scenario used as the loader's reference example and the schema's validation target. One W-2 salaried employee, biweekly pay schedule, no payroll history.",
  "domain": "payroll",
  "baseDemo": "react_sdk_demo_company_onboarded",
  "decorations": {
    "locations": [
      {
        "key": "hq",
        "street_1": "100 Test St",
        "city": "San Francisco",
        "state": "CA",
        "zip": "94105",
        "filing_address": true,
        "mailing_address": true
      }
    ],
    "employees": [
      {
        "key": "alice",
        "$ref": "../fragments/w2-salaried-employee.json"
      }
    ],
    "paySchedule": {
      "frequency": "Every other week",
      "anchor_pay_date": "{{relative:+14d:Friday}}",
      "anchor_end_of_pay_period": "{{relative:+13d}}"
    },
    "payrolls": []
  },
  "expectedContext": ["companyId", "locationIds.hq", "employeeIds.alice", "paySchedule.uuid"]
}
