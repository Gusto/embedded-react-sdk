{
  "$schema": "../../schema/scenario.schema.json",
  "name": "Time off policy create + required field validation",
  "description": "Minimal onboarded company used to drive the create policy form: select policy type, leave required fields blank, assert validation surfaces.",
  "domain": "time-off",
  "baseDemo": "react_sdk_demo_company_onboarded",
  "decorations": {
    "locations": [
      {
        "key": "hq",
        "street_1": "500 3rd Street",
        "city": "San Francisco",
        "state": "CA",
        "zip": "94107",
        "filing_address": true,
        "mailing_address": true
      }
    ],
    "employees": [
      {
        "key": "alice",
        "$ref": "../fragments/w2-salaried-employee.json",
        "overrides": {
          "first_name": "Alice",
          "last_name": "PolicyCreate",
          "email": "alice-policy-create+{{ts}}@example.com"
        }
      }
    ]
  },
  "expectedContext": ["companyId", "locationIds.hq", "employeeIds.alice"]
}
