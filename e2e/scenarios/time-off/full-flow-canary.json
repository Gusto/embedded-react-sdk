{
  "$schema": "../../schema/scenario.schema.json",
  "name": "Time off full-flow canary",
  "description": "Onboarded company with a single salaried employee, used by the time-off canary suite to drive every TimeOffFlow path end-to-end (unlimited create, fixed-accrual create with settings, holiday create, edit-rename, delete) against the demo backend.",
  "domain": "time-off",
  "baseDemo": "react_sdk_demo_company_onboarded",
  "decorations": {
    "locations": [
      {
        "key": "hq",
        "street_1": "500 3rd Street",
        "city": "San Francisco",
        "state": "CA",
        "zip": "94107",
        "filing_address": true,
        "mailing_address": true
      }
    ],
    "employees": [
      {
        "key": "alice",
        "$ref": "../fragments/w2-salaried-employee.json",
        "overrides": {
          "first_name": "Alice",
          "last_name": "Canary",
          "email": "alice-timeoff-canary+{{ts}}@example.com"
        }
      }
    ]
  },
  "expectedContext": ["companyId", "locationIds.hq", "employeeIds.alice"]
}
