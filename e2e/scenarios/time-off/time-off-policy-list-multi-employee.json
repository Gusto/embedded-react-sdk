{
  "$schema": "../../schema/scenario.schema.json",
  "name": "Time off policy list with multi-employee roster",
  "description": "Onboarded company with several employees so the policy list and add-employees grids have realistic volume.",
  "domain": "time-off",
  "baseDemo": "react_sdk_demo_company_onboarded",
  "decorations": {
    "locations": [
      {
        "key": "hq",
        "street_1": "200 Market St",
        "city": "San Francisco",
        "state": "CA",
        "zip": "94105",
        "filing_address": true,
        "mailing_address": true
      }
    ],
    "employees": [
      {
        "key": "alice",
        "$ref": "../fragments/w2-salaried-employee.json",
        "overrides": {
          "first_name": "Alice",
          "last_name": "PolicyList",
          "email": "alice-policy-list+{{ts}}@example.com",
          "onboarding_status": "onboarding_completed"
        }
      },
      {
        "key": "bob",
        "$ref": "../fragments/w2-hourly-employee.json",
        "overrides": {
          "first_name": "Bob",
          "last_name": "PolicyList",
          "email": "bob-policy-list+{{ts}}@example.com",
          "onboarding_status": "onboarding_completed"
        }
      },
      {
        "key": "carol",
        "$ref": "../fragments/w2-salaried-employee.json",
        "overrides": {
          "first_name": "Carol",
          "last_name": "PolicyList",
          "email": "carol-policy-list+{{ts}}@example.com",
          "onboarding_status": "onboarding_completed"
        }
      }
    ]
  },
  "expectedContext": [
    "companyId",
    "locationIds.hq",
    "employeeIds.alice",
    "employeeIds.bob",
    "employeeIds.carol"
  ]
}
