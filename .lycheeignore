# Hosts that consistently rate-limit or block CI link probes.
# Add entries here only after a real CI failure traces back to flake, not
# an actual broken link. Each line is a regex against the full URL.
^https?://(?:www\.)?linkedin\.com/
^https?://(?:www\.)?twitter\.com/
^https?://(?:www\.)?x\.com/

# Internal Gusto hosts that are unreachable from public CI runners.
^https?://[a-z0-9-]+\.gusto-corp\.com/
^https?://[a-z0-9-]+\.gusto-demo\.com/
^https?://gws-flows\.gusto\.com/

# Google Docs / Drive / Sheets links require auth and return 401/403 from
# anonymous probes, so we skip them rather than fail the gate.
^https?://docs\.google\.com/
^https?://drive\.google\.com/
^https?://sheets\.google\.com/

# Notion shares behind workspace auth.
^https?://(?:[a-z0-9-]+\.)?notion\.(?:so|site)/
