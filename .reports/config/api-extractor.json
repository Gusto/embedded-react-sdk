{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",
  "projectFolder": "../../",
  "mainEntryPointFilePath": "<projectFolder>/dist/index.d.ts",
  "bundledPackages": [],
  "compiler": {
    "tsconfigFilePath": "<projectFolder>/.reports/config/tsconfig.json"
  },
  "apiReport": {
    "enabled": true,
    "reportFolder": "<projectFolder>/.reports/",
    "reportTempFolder": "<projectFolder>/.reports/temp/",
    "reportVariants": [
      "public"
    ]
  },
  "docModel": {
    "enabled": false
  },
  "dtsRollup": {
    "enabled": false
  },
  "tsdocMetadata": {
    "enabled": false
  },
  "messages": {
    "extractorMessageReporting": {
      "ae-missing-release-tag": {
        "logLevel": "none",
        "addToApiReportFile": true
      },
      "ae-forgotten-export": {
        "logLevel": "none",
        "addToApiReportFile": true
      },
      "ae-unresolved-link": {
        "logLevel": "none",
        "addToApiReportFile": true
      },
      "ae-incompatible-release-tags": {
        "logLevel": "none",
        "addToApiReportFile": true
      }
    }
  }
}